#include <iostream>
using namespace std;

const int SIZE = 5;
int queue[SIZE];
int front = -1, rear = -1;

int main()
{
    int choice, value;

    do
    {
        cout << "\n--- Queue Operations ---\n";
        cout << "1. Enqueue (Insert)\n";
        cout << "2. Dequeue (Delete)\n";
        cout << "3. Peek (Front Element)\n";
        cout << "4. Exit\n";
        cout << "Enter your choice: ";
        cin >> choice;

        switch (choice)
        {
        case 1: // Enqueue
            if (rear == SIZE - 1)
            {
                cout << "Queue is Full!\n";
            }
            else
            {
                if (front == -1)
                    front = 0;

                cout << "Enter value: ";
                cin >> value;

                rear++;
                queue[rear] = value;

                cout << "Value inserted in queue.\n";
            }
            break;

        case 2: // Dequeue
            if (front == -1 || front > rear)
            {
                cout << "Queue is Empty!\n";
            }
            else
            {
                cout << "Deleted element: " << queue[front] << endl;
                front++;

                if (front > rear)
                {
                    front = -1;
                    rear = -1;
                }
            }
            break;

        case 3: // Peek
            if (front == -1)
            {
                cout << "Queue is Empty!\n";
            }
            else
            {
                cout << "Front element is: " << queue[front] << endl;
            }
            break;

        case 4:
            cout << "Program Exit.\n";
            break;

        default:
            cout << "Invalid choice!\n";
        }

    } while (choice != 4);

    return 0;
}
